# .env.example — PsyFusions
# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# ─── Telegram Bot (для уведомлений о заявках) ──────────────────
# Создай бота через @BotFather в Telegram
TELEGRAM_BOT_TOKEN=

# Узнай свой ID через бота @userinfobot
# Для группы/канала: сначала добавь бота, потом скопируй ID
TELEGRAM_CHAT_ID=

# ─── Google AI (не используется сейчас) ────────────────────────
GEMINI_API_KEY=

# ─── Сервер ────────────────────────────────────────────────────
# PORT по умолчанию: 3000
# PORT=3000
